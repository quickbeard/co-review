// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum GitProviderType {
  github
  gitlab
  bitbucket
  azure_devops
  gitea
  gerrit
}


// =============================================================================
// Core Models
// =============================================================================

model Organization {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  gitProviders GitProvider[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model GitProvider {
  id             String          @id @default(cuid())
  type           GitProviderType
  name           String
  baseUrl        String?         // For self-hosted instances (GitLab, Gitea, etc.)
  accessToken    String          // Encrypted in application layer
  webhookSecret  String?
  isActive       Boolean         @default(true)
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repositories   Repository[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organizationId, type, name])
}

model Repository {
  id            String      @id @default(cuid())
  externalId    String      // Repository ID from git provider
  name          String
  fullName      String      // e.g., "org/repo"
  defaultBranch String      @default("main")
  isActive      Boolean     @default(true) // Enable/disable reviews
  settings      Json?       // Repository-specific PR-Agent settings override
  gitProviderId String
  gitProvider   GitProvider @relation(fields: [gitProviderId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([gitProviderId, externalId])
}

