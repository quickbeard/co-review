# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=pr_agent
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# OpenAI / LLM gateway (used by the AI reviewer and Mem0 embeddings)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# DevLake API (used by PR-Agent backend integration service)
# Base URL of your DevLake API server (without trailing slash)
# Example: http://localhost:8080
DEVLAKE_API_BASE_URL=
# API route prefix exposed by DevLake (no trailing slash). Use /api/rest if your
# deployment serves the REST API under that path (common with the DevLake UI port).
DEVLAKE_API_PREFIX=/api
# Optional API auth token if your DevLake instance requires authentication.
DEVLAKE_API_TOKEN=
# Optional auth header/scheme override; defaults match Bearer auth.
DEVLAKE_API_AUTH_HEADER=Authorization
DEVLAKE_API_AUTH_SCHEME=Bearer
# Request timeout in seconds for backend->DevLake API calls.
DEVLAKE_API_TIMEOUT_SEC=30
# Set to false only for self-signed/dev TLS endpoints.
DEVLAKE_API_VERIFY_TLS=true

# Dashboard: URL of an Apache DevLake Grafana dashboard to embed on the
# Analytics page. Leave empty to hide the embed. The referenced Grafana
# instance must allow embedding (grafana.ini → security.allow_embedding=true).
# Example (Apache DevLake default port on host machine):
#   NEXT_PUBLIC_DEVLAKE_GRAFANA_URL=http://localhost:3002/d/<uid>/<slug>?orgId=1&kiosk=tv&theme=light
NEXT_PUBLIC_DEVLAKE_GRAFANA_URL=
