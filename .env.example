# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pr_agent
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# OpenAI / LLM gateway (used by the AI reviewer and Mem0 embeddings)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Apache DevLake local stack in docker-compose (profile: devlake)
DEVLAKE_VERSION=v1.0.2
DEVLAKE_TZ=UTC
DEVLAKE_UI_HOST_PORT=30090
DEVLAKE_MYSQL_HOST_PORT=3306
DEVLAKE_MYSQL_ROOT_PASSWORD=admin
DEVLAKE_MYSQL_DATABASE=lake
DEVLAKE_MYSQL_USER=merico
DEVLAKE_MYSQL_PASSWORD=merico
# DevLake core DB URL consumed by the devlake container.
DB_URL=mysql://${DEVLAKE_MYSQL_USER}:${DEVLAKE_MYSQL_PASSWORD}@devlake-mysql:3306/${DEVLAKE_MYSQL_DATABASE}?charset=utf8mb4&parseTime=True&loc=UTC
# Required by DevLake to encrypt source credentials/tokens at rest.
# Run: openssl rand -base64 2000 | tr -dc 'A-Z' | fold -w 128 | head -n 1
# then copy the result and paste it here
ENCRYPTION_SECRET=
# Configures grafana links served through devlake-config-ui.
DEVLAKE_GRAFANA_ROOT_URL=http://localhost:${DEVLAKE_UI_HOST_PORT}/grafana
# Grafana admin credentials (used by devlake-grafana container).
DEVLAKE_GRAFANA_ADMIN_USER=admin
DEVLAKE_GRAFANA_ADMIN_PASSWORD=admin

# DevLake API (used by PR-Agent backend integration service)
# Base URL of your DevLake API server (without trailing slash)
# Example: http://localhost:8080
DEVLAKE_API_BASE_URL=http://devlake:8080
# API route prefix exposed by DevLake (no trailing slash). Use /api/rest if your
# deployment serves the REST API under that path (common with the DevLake UI port).
DEVLAKE_API_PREFIX=/api
# Optional API auth token if your DevLake instance requires authentication.
DEVLAKE_API_TOKEN=
# Optional auth header/scheme override; defaults match Bearer auth.
DEVLAKE_API_AUTH_HEADER=Authorization
DEVLAKE_API_AUTH_SCHEME=Bearer
# Request timeout in seconds for backend->DevLake API calls.
DEVLAKE_API_TIMEOUT_SEC=30
# Set to false only for self-signed/dev TLS endpoints.
DEVLAKE_API_VERIFY_TLS=true

# Dashboard: URL of an Apache DevLake Grafana dashboard to embed on the
# Analytics page. Leave empty to hide the embed. The referenced Grafana
# instance must allow embedding (grafana.ini → security.allow_embedding=true).
# Example (Apache DevLake default port on host machine):
#   NEXT_PUBLIC_DEVLAKE_GRAFANA_URL=http://localhost:30090/d/<uid>/<slug>?orgId=1&kiosk&theme=light
NEXT_PUBLIC_DEVLAKE_GRAFANA_URL=
